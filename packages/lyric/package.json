{
	"name": "@applemusic-like-lyrics/lyric",
	"version": "0.4.1",
	"description": "一个歌词解析/生成模块，着重于歌词内容解析，支持多种格式",
	"repository": {
		"url": "https://github.com/amll-dev/applemusic-like-lyrics.git",
		"directory": "packages/lyric",
		"type": "git"
	},
	"license": "GPL-3.0",
	"type": "module",
	"files": [
		"dist",
		"pkg"
	],
	"main": "./dist/amll-lyric.umd.cjs",
	"module": "./dist/amll-lyric.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/amll-lyric.js",
			"require": "./dist/amll-lyric.umd.cjs"
		}
	},
	"scripts": {
		"build:docs": "typedoc --plugin typedoc-plugin-markdown --out docs src/index.ts",
		"typecheck": "tsc --noEmit",
		"build:wasm": "wasm-pack build rust --target bundler --release --out-dir ../pkg --out-name amll_lyric",
		"build:wasm:dev": "wasm-pack build rust --target bundler --dev --out-dir ../pkg --out-name amll_lyric",
		"vite-build:main": "vite build",
		"build-only": "run-s build:wasm vite-build:main",
		"build": "run-s build:wasm typecheck vite-build:main",
		"build:dev": "run-s build:wasm:dev typecheck vite-build:main",
		"fmt": "biome format --write ./src",
		"dev": "vite dev",
		"preinstall": "npx only-allow pnpm"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"typescript": "^5.9.3",
		"vite": "catalog:",
		"vite-plugin-dts": "^4.3.0",
		"vite-plugin-wasm": "catalog:"
	}
}
